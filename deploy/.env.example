# Copy to deploy/.env and fill in. Used by build.sh + deploy.sh.
# deploy/.env is gitignored (.env / .env.* are already in .dockerignore + repo ignore).

# ---- image (private registry — it contains your source) ----------------------
IMAGE=kirankk1304/zapthetrick-runpod
IMAGE_TAG=latest

# ---- RunPod (for deploy.sh; not needed if you deploy via the saved template) --
RUNPOD_API_KEY=rpa_your_runpod_api_key_here
RUNPOD_VOLUME_ID=your_network_volume_id
POD_NAME=zapthetrick
CONTAINER_DISK_GB=40
# First available wins. All run the cu124 image (24–48 GB Ampere/Ada). NOT 50-series.
GPU_PRIORITY="NVIDIA A40,NVIDIA RTX A6000,NVIDIA L40S,NVIDIA GeForce RTX 4090,NVIDIA RTX A5000"

# ---- pod runtime env (the pod self-configures from these) --------------------
APP_PORT=8888

# The master key that ENCRYPTS the provider keys you add in the Providers UI.
# Set it and keep it STABLE forever — if it changes, your stored keys become
# undecryptable. Must be 64 hex chars (32 bytes). Generate once:
#   python -c "import secrets; print(secrets.token_hex(32))"
ZAPTHETRICK_ENCRYPTION_KEY=REDACTED_ENCRYPTION_KEY

# Recommended: a stable DB password (defaults to 'zaptrick' if blank).
POSTGRES_PASSWORD=
